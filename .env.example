# CRM API (server/)
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# JWT (обязательно сменить в production)
JWT_SECRET=replace-with-at-least-32-random-chars
# Срок жизни токена: "8h", "1d" или секунды (например 86400)
JWT_EXPIRES_IN=8h

# SQLite — мероприятия и локальные пользователи (путь от папки server/)
SQLITE_PATH=../data/crm.sqlite
UPLOAD_DIR=../data/uploads
UPLOAD_MAX_BYTES=26214400

# Seed только при пустой таблице users (в production пароль не "admin")
SEED_USER_LOGIN=admin
SEED_USER_PASSWORD=change-me-in-production

# При старте API также создаются (если нет): manager/manager, moderator/moderator, user/user
# manager — график markova; moderator привязан к manager

# Участники CRM на 172.17.30.42 (не используется для входа)
CRM_MOCK=true
# Вкладка «Пользователи»: при CRM_MOCK — server/db/reference/user.sql; иначе MySQL crm.user
# CRM_DB_HOST=172.17.30.42
# CRM_DB_PORT=3306
# CRM_DB_USER=crm
# CRM_DB_PASSWORD=
# CRM_DB_NAME=crm
# CRM_BASE_URL=https://172.17.30.42
# CRM_PARTICIPANTS_PATH=/api/users.php
# CRM_SYNC_SECRET=replace-in-production
# CRM_HOST_HEADER=asu.admsr.ru
# CRM_TIMEOUT_MS=5000
