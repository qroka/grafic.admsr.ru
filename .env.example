# CRM API (server/) — grafic.admsr.ru
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=https://grafic.admsr.ru

JWT_SECRET=replace-with-at-least-32-random-chars
JWT_EXPIRES_IN=8h

SQLITE_PATH=../data/crm.sqlite
UPLOAD_DIR=../data/uploads
UPLOAD_MAX_BYTES=26214400

SEED_USER_LOGIN=admin
SEED_USER_PASSWORD=change-me-in-production

# Участники — HTTP к CRM (как corporate → asu_lookup). Порт 3306 с grafic не открывают.
CRM_MOCK=false
CRM_BASE_URL=https://crm.admsr.ru
CRM_PARTICIPANTS_PATH=/crm_participants.php
CRM_HOST_HEADER=crm.admsr.ru
CRM_SYNC_SECRET=общий-секрет-с-CRM_LOOKUP_SECRET_на_CRM
CRM_LOOKUP_URL=https://crm.admsr.ru/crm_lookup.php
CRM_TIMEOUT_MS=5000

# Прямой MySQL с grafic (опционально):
# CRM_DB_HOST=172.17.30.42
# CRM_DB_USER=root
# CRM_DB_PASSWORD=
# CRM_DB_NAME=crm

# Почта (через CRM 30.42 — crm_send_mail.php, postfix на grafic не нужен)
# MAIL_ENABLED=true
# MAIL_TRANSPORT=crm
# CRM_MAIL_PATH=/crm_send_mail.php
