# Production / systemd (EnvironmentFile=server/.env)
# Скопируйте: cp .env.example server/.env  или  cp ../.env server/.env

NODE_ENV=production
PORT=3001
HOST=127.0.0.1
CORS_ORIGIN=https://grafic.admsr.ru

JWT_SECRET=replace-with-at-least-32-random-chars
JWT_EXPIRES_IN=8h

SQLITE_PATH=/var/lib/crm-schedule/crm.sqlite
UPLOAD_DIR=/var/lib/crm-schedule/uploads

SEED_USER_LOGIN=admin
SEED_USER_PASSWORD=change-me-in-production

CRM_MOCK=false
CRM_BASE_URL=https://crm.admsr.ru
CRM_PARTICIPANTS_PATH=/crm_participants.php
CRM_HOST_HEADER=crm.admsr.ru
CRM_SYNC_SECRET=общий-секрет-с-CRM_LOOKUP_SECRET_на_CRM
CRM_LOOKUP_URL=https://crm.admsr.ru/crm_lookup.php
CRM_TIMEOUT_MS=5000

# Опционально — прямой MySQL к 30.42 (иначе HTTP crm_participants.php):
# CRM_DB_HOST=172.17.30.42
# CRM_DB_USER=root
# CRM_DB_PASSWORD=
# CRM_DB_NAME=crm

# Почта для уведомлений о мероприятиях
MAIL_ENABLED=true
MAIL_TRANSPORT=crm
CRM_MAIL_PATH=/crm_send_mail.php
MAIL_FROM=postmaster@admsr.ru
MAIL_REPLY_TO=postmaster@admsr.ru
MAIL_SUBJECT_PREFIX=График заместителей
# MAIL_BLACKLIST=eua@admsr.ru,kov@admsr.ru,ostrond@admsr.ru
# Локальный sendmail (если MAIL_TRANSPORT=sendmail):
# MAIL_SENDMAIL_PATH=/usr/sbin/sendmail
